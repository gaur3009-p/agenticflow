# ============================================================
# AgenticFlow — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- App ---
APP_ENV=development
APP_NAME=AgenticFlow
APP_VERSION=2.4.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://agenticflow:password@localhost:5432/agenticflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# --- Redis (Celery + Cache) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DATASETS=agenticflow-datasets
S3_BUCKET_MODELS=agenticflow-models

# --- FREE LLM Inference ---
# Groq (free tier — very fast, no GPU needed)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama (local, completely free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# Together AI (generous free tier)
TOGETHER_API_KEY=your_together_key_here

# --- Optional Paid Models ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Auth (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
GITHUB_CLIENT_ID=your_github_oauth_id
GITHUB_CLIENT_SECRET=your_github_oauth_secret
GOOGLE_CLIENT_ID=your_google_oauth_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# --- Docker Sandbox ---
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=agenticflow/sandbox:latest
SANDBOX_NETWORK=agenticflow_sandbox
SANDBOX_MAX_CONTAINERS=50
SANDBOX_TTL_SECONDS=3600

# --- Training ---
HF_TOKEN=hf_your_huggingface_token
HF_CACHE_DIR=/tmp/hf_cache
TRAINING_GPU_ENABLED=false         # set true if you have CUDA GPU
TRAINING_MAX_JOBS=3
LORA_OUTPUT_DIR=./lora_outputs

# --- Eval ---
EVAL_JUDGE_MODEL=llama3.1:70b      # or gpt-4o-mini if you have key
EVAL_BATCH_SIZE=10

# --- Monitoring ---
SENTRY_DSN=https://your-sentry-dsn
POSTHOG_KEY=phc_your_posthog_key
